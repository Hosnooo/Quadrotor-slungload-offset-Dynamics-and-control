<Group labelreference="L69" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">Kinematics and energies</Font></Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L70" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">omegaHat := Skew(omega):
OmegaHat := Skew(Omega):
qHat := Skew(q):
rHat := Skew(rVec):

qdot :=
    simplify(
        omegaHat . q
    );

Rdot :=
    simplify(
        R . OmegaHat
    );

xQ :=
    simplify(
        xL
        - L*q
        - R . rVec
    );

vQ :=
    simplify(
        vL
        - L*qdot
        - Rdot . rVec
    );

GenVel_t :=
    Vector[column](9, [
        v__L1(t),
        v__L2(t),
        v__L3(t),

        omega__1(t),
        omega__2(t),
        omega__3(t),

        Omega__1(t),
        Omega__2(t),
        Omega__3(t)
    ]):

K :=
    simplify(
        (1/2)*m__L*Dot(vL, vL)
        + (1/2)*m__Q*Dot(vQ, vQ)
        + (1/2)*Dot(Omega, J . Omega)
    ):

V :=
    simplify(
        - m__L*g*Dot(e3, xL)
        - m__Q*g*Dot(e3, xQ)
    ):</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
