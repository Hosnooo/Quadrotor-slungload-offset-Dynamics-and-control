</Group>
<Group hide-input="false" labelreference="L78" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">dV_alg :=
    simplify(
        add(
            diff(V_alg, xL_alg[i])*delta_xL[i],
            i=1..3
        )
        +
        add(
            diff(V_alg, q_alg[i])*delta_q[i],
            i=1..3
        )
        +
        add(
            add(
                diff(V_alg, R_alg[i,j])*delta_R[i,j],
                j=1..3
            ),
            i=1..3
        )
    ):

H_alg :=
    Vector[column](9,
        i -&gt;
            simplify(
                diff(dV_alg, Eta_alg[i])
            )
    );

H_check :=
    simplify(
        dV_alg
        - add(
            H_alg[i]*Eta_alg[i],
            i=1..9
        )
    );</Text-field>
</Input>
