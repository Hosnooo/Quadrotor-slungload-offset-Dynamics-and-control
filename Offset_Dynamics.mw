<Group labelreference="L79" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">Generalized input forces</Font></Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L80" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">b3_alg :=
    R_alg . Vector[column](3, [
        0,
        0,
        1
    ]):

F_alg :=
    simplify(
        u__t*b3_alg
    ):

delta_xQ :=
    simplify(
        delta_xL
        - L*delta_q
        - delta_R . rVec
    ):

dW_alg :=
    simplify(
        Dot(F_alg, delta_xQ)
        + Dot(tau_alg, Eta_Omega)
    ):

Q_alg :=
    Vector[column](9,
        i -&gt;
            simplify(
                diff(dW_alg, Eta_alg[i])
            )
    );

Q_check :=
    simplify(
        dW_alg
        - add(
            Q_alg[i]*Eta_alg[i],
            i=1..9
        )
    );</Text-field>
</Input>
