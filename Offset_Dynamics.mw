<Group hide-input="false" labelreference="L94" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">StateDot_dim_check :=
    evalb(
        LinearAlgebra:-Dimension(StateDot) = 24
    );

StateDot_x_check :=
    simplify(
        Vector[column](3, [
            StateDot[1],
            StateDot[2],
            StateDot[3]
        ])
        -
        vL_alg
    );

StateDot_q_check :=
    simplify(
        Vector[column](3, [
            StateDot[4],
            StateDot[5],
            StateDot[6]
        ])
        -
        qdot_alg
    );

StateDot_R_check :=
    simplify(
        Vector[column](9, [
            StateDot[7],
            StateDot[8],
            StateDot[9],
            StateDot[10],
            StateDot[11],
            StateDot[12],
            StateDot[13],
            StateDot[14],
            StateDot[15]
        ])
        -
        Rdot_vec_alg
    );

StateDot_v_check :=
    simplify(
        Vector[column](3, [
            StateDot[16],
            StateDot[17],
            StateDot[18]
        ])
        -
        Vector[column](3, [
            GenAcc_rhs[1],
            GenAcc_rhs[2],
            GenAcc_rhs[3]
        ])
    );

StateDot_omega_check :=
    simplify(
        Vector[column](3, [
            StateDot[19],
            StateDot[20],
            StateDot[21]
        ])
        -
        Vector[column](3, [
            GenAcc_rhs[4],
            GenAcc_rhs[5],
            GenAcc_rhs[6]
        ])
    );

StateDot_Omega_check :=
    simplify(
        Vector[column](3, [
            StateDot[22],
            StateDot[23],
            StateDot[24]
        ])
        -
        Vector[column](3, [
            GenAcc_rhs[7],
            GenAcc_rhs[8],
            GenAcc_rhs[9]
        ])
    );

GenAcc_from_StateDot :=
    Vector[column](9, [
        StateDot[16],
        StateDot[17],
        StateDot[18],

        StateDot[19],
        StateDot[20],
        StateDot[21],

        StateDot[22],
        StateDot[23],
        StateDot[24]
    ]):

StateDot_dyn_check :=
    simplify(
        M_alg . GenAcc_from_StateDot
        + C_alg
        + H_alg
        - Q_alg
    );

StateDot_diff_check :=
    indets(StateDot, specfunc(anything, diff));</Text-field>
