<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">qdot_alg :=
    simplify(
        Skew(omega_alg) . q_alg
    ):

Rdot_alg :=
    simplify(
        R_alg . Skew(Omega_alg)
    ):

Rdot_vec_alg :=
