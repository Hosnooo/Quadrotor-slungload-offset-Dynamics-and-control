<Group labelreference="L71" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" size="20" layout="Normal"><Font size="20">Algebraic variables</Font></Text-field>
</Input>
</Group>
<Group labelreference="L72" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Alg_subs :=
    {
        x__L1(t) = x__L1,
        x__L2(t) = x__L2,
        x__L3(t) = x__L3,

        v__L1(t) = v__L1,
        v__L2(t) = v__L2,
        v__L3(t) = v__L3,

        q__1(t) = q__1,
        q__2(t) = q__2,
        q__3(t) = q__3,

        R__11(t) = R__11,
        R__12(t) = R__12,
        R__13(t) = R__13,
        R__21(t) = R__21,
        R__22(t) = R__22,
        R__23(t) = R__23,
        R__31(t) = R__31,
        R__32(t) = R__32,
        R__33(t) = R__33,

        omega__1(t) = omega__1,
        omega__2(t) = omega__2,
        omega__3(t) = omega__3,

        Omega__1(t) = Omega__1,
        Omega__2(t) = Omega__2,
        Omega__3(t) = Omega__3,

        T(t) = u__t,
        tau__1(t) = tau__1,
        tau__2(t) = tau__2,
        tau__3(t) = tau__3
    }:

xL_alg :=
    Vector[column](3, [
        x__L1,
        x__L2,
        x__L3
    ]):

vL_alg :=
    Vector[column](3, [
        v__L1,
        v__L2,
        v__L3
    ]):

q_alg :=
    Vector[column](3, [
        q__1,
        q__2,
        q__3
    ]):

R_alg :=
    Matrix(3, 3, [
        [R__11, R__12, R__13],
        [R__21, R__22, R__23],
        [R__31, R__32, R__33]
    ]):

omega_alg :=
    Vector[column](3, [
        omega__1,
        omega__2,
        omega__3
    ]):

Omega_alg :=
    Vector[column](3, [
        Omega__1,
        Omega__2,
        Omega__3
    ]):

tau_alg :=
    Vector[column](3, [
        tau__1,
        tau__2,
        tau__3
    ]):

Input_alg :=
    Vector[column](4, [
        u__t,
        tau__1,
        tau__2,
        tau__3
    ]):

Param_alg := [
    m__Q,
    m__L,
    L,
    g,
    r__1,
    r__2,
    r__3,
    J__1,
    J__2,
    J__3
]:

GenVel_alg :=
    Vector[column](9, [
        v__L1,
        v__L2,
        v__L3,

        omega__1,
        omega__2,
        omega__3,

        Omega__1,
        Omega__2,
        Omega__3
    ]):

GenAcc_sym :=
    Vector[column](9, [
        a__L1,
        a__L2,
        a__L3,

        omegadot__1,
        omegadot__2,
        omegadot__3,

        Omegadot__1,
        Omegadot__2,
        Omegadot__3
    ]):

K_alg :=
    simplify(
        subs(Alg_subs, K)
    ):

V_alg :=
    simplify(
        subs(Alg_subs, V)
    ):</Text-field>
</Input>
</Group>
<Group labelreference="L73" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" size="20" layout="Normal"><Font size="20">Mass matrix</Font></Text-field>
