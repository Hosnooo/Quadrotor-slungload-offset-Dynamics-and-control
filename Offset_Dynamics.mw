<Group hide-input="false" labelreference="L66" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">vars := [
    x__L1(t), x__L2(t), x__L3(t),
    v__L1(t), v__L2(t), v__L3(t),

    q__1(t), q__2(t), q__3(t),

    R__11(t), R__12(t), R__13(t),
    R__21(t), R__22(t), R__23(t),
    R__31(t), R__32(t), R__33(t),

    omega__1(t), omega__2(t), omega__3(t),
    Omega__1(t), Omega__2(t), Omega__3(t),

    T(t),
    tau__1(t), tau__2(t), tau__3(t)
]:

Suppress(vars):

Mt := m__Q + m__L;

Cross := proc(a,b)
    local out;

    out :=
        Vector[column](3, [
            a[2]*b[3] - a[3]*b[2],
            a[3]*b[1] - a[1]*b[3],
            a[1]*b[2] - a[2]*b[1]
        ]);

    return out;
end proc:

Dot := proc(a,b)
    local i, out;

    out := add(a[i]*b[i], i=1..3);

    return out;
end proc:

Skew := proc(a)
    local out;

    out :=
        Matrix(3, 3, [
            [0,     -a[3],  a[2]],
            [a[3],   0,    -a[1]],
            [-a[2],  a[1],  0   ]
        ]);

    return out;
end proc:</Text-field>
</Input>
