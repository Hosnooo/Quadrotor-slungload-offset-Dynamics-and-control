<Group labelreference="L95" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">Full input-affine model</Font></Text-field>
</Input>
</Group>
<Group labelreference="L96" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Input_zero_subs :=
    {
        u__t = 0,
        tau__1 = 0,
        tau__2 = 0,
        tau__3 = 0
    }:

xdot :=
    StateDot:

f :=
    simplify(
        subs(Input_zero_subs, xdot)
    ):

Gmat :=
    Matrix(24, 4,
        (i,j) -&gt;
            simplify(
                diff(xdot[i], Input_alg[j])
            )
    ):

affine_check :=
    simplify(
        xdot - (f + Gmat . Input_alg)
    ):</Text-field>
</Input>
</Group>
<Group labelreference="L99" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">Export matlab model</Font></Text-field>
</Input>
</Group>
<Group labelreference="L100" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">read &quot;matlabsims.mpl&quot;:

outdir := &quot;matlab_core_offset&quot;:

EnsureFolder(outdir):

WriteModelFile(
    outdir,
    &quot;model_offset&quot;,
    convert(State_alg, list),
    f,
    Gmat,
    Param_alg
):</Text-field>
</Input>
</Group>
<Group labelreference="L103" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">Extract Equilibrium Point</Font></Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L102" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;==================================================\134n&quot;):
printf(&quot;Solving exact hover equilibrium from exact offset dynamics\134n&quot;):
printf(&quot;==================================================\134n&quot;):
</Font>
hover_known :=
    [
        q__1 = 0,
        q__2 = 0,
        q__3 = 1,

        R__11 = 1,
        R__12 = 0,
        R__13 = 0,

        R__21 = 0,
        R__22 = 1,
        R__23 = 0,

        R__31 = 0,
        R__32 = 0,
        R__33 = 1,

        v__L1 = 0,
        v__L2 = 0,
        v__L3 = 0,

        omega__1 = 0,
        omega__2 = 0,
        omega__3 = 0,

        Omega__1 = 0,
        Omega__2 = 0,
        Omega__3 = 0
    ]:

xQ_origin_eqs :=
    {
        simplify(
            subs(
                hover_known,
                x__L1
                - L*q__1
                - (R__11*r__1 + R__12*r__2 + R__13*r__3)
            )
        ) = 0,

        simplify(
            subs(
                hover_known,
                x__L2
                - L*q__2
                - (R__21*r__1 + R__22*r__2 + R__23*r__3)
            )
        ) = 0,

        simplify(
            subs(
                hover_known,
                x__L3
                - L*q__3
                - (R__31*r__1 + R__32*r__2 + R__33*r__3)
            )
        ) = 0
    }:

xdot_affine :=
    simplify(
        f + Gmat . Input_alg
    ):

hover_residual :=
    Vector[column](
        24,
        k -&gt; simplify(
            normal(
                subs(hover_known, xdot_affine[k])
            )
        )
    ):

dynamic_hover_eqs := {}:

for k from 1 to 24 do

    eq_k :=
        simplify(
            numer(
                normal(
                    hover_residual[k]
                )
            )
        ):

    if not evalb(eq_k = 0) then
        dynamic_hover_eqs :=
            dynamic_hover_eqs union {eq_k = 0}:
    end if:

od:

equilibrium_eqs :=
    dynamic_hover_eqs union xQ_origin_eqs:

sol_equilibrium :=
    solve(
        equilibrium_eqs,
        {
            x__L1,
            x__L2,
            x__L3,
            u__t,
            tau__1,
            tau__2,
            tau__3
        }
    ):

if type(sol_equilibrium, list) then
    sol_equilibrium := sol_equilibrium[1]:
end if:

xeq :=
    [
        x__L1 = simplify(subs(sol_equilibrium, x__L1)),
        x__L2 = simplify(subs(sol_equilibrium, x__L2)),
        x__L3 = simplify(subs(sol_equilibrium, x__L3)),

        op(hover_known)
    ]:

ueq :=
    [
        u__t   = simplify(subs(sol_equilibrium, u__t)),
        tau__1 = simplify(subs(sol_equilibrium, tau__1)),
        tau__2 = simplify(subs(sol_equilibrium, tau__2)),
        tau__3 = simplify(subs(sol_equilibrium, tau__3))
    ]:

eqPoint :=
    [op(xeq), op(ueq)]:

u0 :=
    Vector[column](
        [
            rhs(ueq[1]),
            rhs(ueq[2]),
            rhs(ueq[3]),
            rhs(ueq[4])
        ]
    ):

trim_residual :=
    Vector[column](
        24,
        k -&gt; simplify(
            normal(
                subs(eqPoint, xdot_affine[k])
            )
        )
    ):

trim_nonzero := []:

for k from 1 to 24 do

    res_k :=
        simplify(
            normal(
                trim_residual[k]
            )
        ):

    if not evalb(res_k = 0) then
        trim_nonzero :=
            [op(trim_nonzero), k = res_k]:
    end if:

od:

print(&quot;sol_equilibrium =&quot;, sol_equilibrium):
print(&quot;xeq =&quot;, xeq):
print(&quot;ueq =&quot;, ueq):
print(&quot;u0 =&quot;, u0):
print(&quot;trim_nonzero =&quot;, trim_nonzero):</Text-field>
</Input>
