<Group labelreference="L89" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">Full dynamics</Font></Text-field>
</Input>
</Group>
<Group labelreference="L90" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ============================================================
# Full dynamics with cable angular-velocity constraint
# ============================================================

RHS_dyn_alg :=
    simplify(
        Q_alg - C_alg - H_alg
    ):

# Constraint:
# q^T omegadot = 0
#
# GenAcc_sym = [aL; omegadot; Omegadot]
ConstraintCol_alg :=
    Vector[column](9, [
        0,
        0,
        0,

        q__1,
        q__2,
        q__3,

        0,
        0,
        0
    ]):

# Bordered system:
# [ M      c ][acc   ] = [RHS]
# [ c^T    0 ][lambda]   [0  ]
#
# This imposes c^T acc = 0 while preserving the original equations.
M_aug_alg :=
    Matrix(10, 10,
        (i,j) -&gt;
            piecewise(
                i &lt;= 9 and j &lt;= 9,
                    M_alg[i,j],

                i &lt;= 9 and j = 10,
                    ConstraintCol_alg[i],

                i = 10 and j &lt;= 9,
                    ConstraintCol_alg[j],

                0
            )
    ):

RHS_aug_alg :=
    Vector[column](10, [
        seq(RHS_dyn_alg[i], i=1..9),
        0
    ]):

AugSol_alg :=
    simplify(
        LinearSolve(
            M_aug_alg,
            RHS_aug_alg
        )
    ):

GenAcc_rhs :=
    simplify(
        Vector[column](9, [
            seq(AugSol_alg[i], i=1..9)
        ])
    ):

lambda_constraint :=
    simplify(
        AugSol_alg[10]
    ):

aL_rhs :=
    Vector[column](3, [
        GenAcc_rhs[1],
        GenAcc_rhs[2],
        GenAcc_rhs[3]
    ]):

omegadot_rhs :=
    Vector[column](3, [
        GenAcc_rhs[4],
        GenAcc_rhs[5],
        GenAcc_rhs[6]
    ]):

Omegadot_rhs :=
    Vector[column](3, [
        GenAcc_rhs[7],
        GenAcc_rhs[8],
        GenAcc_rhs[9]
    ]):</Text-field>
</Input>
</Group>
<Group labelreference="L91" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal"><Font size="20">State derivative</Font></Text-field>
</Input>
</Group>
<Group labelreference="L92" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">State_alg :=
    Vector[column](24, [
        x__L1,
        x__L2,
        x__L3,

        q__1,
        q__2,
        q__3,

        R__11,
        R__12,
        R__13,
        R__21,
        R__22,
        R__23,
        R__31,
        R__32,
        R__33,

        v__L1,
        v__L2,
        v__L3,

        omega__1,
        omega__2,
        omega__3,

        Omega__1,
        Omega__2,
        Omega__3
    ]):

StateDot_sym :=
    Vector[column](24, [
        xdot__L1,
        xdot__L2,
        xdot__L3,

        qdot__1,
        qdot__2,
        qdot__3,

        Rdot__11,
        Rdot__12,
        Rdot__13,
        Rdot__21,
        Rdot__22,
        Rdot__23,
        Rdot__31,
        Rdot__32,
        Rdot__33,

        vdot__L1,
        vdot__L2,
        vdot__L3,

        omegadot__1,
        omegadot__2,
        omegadot__3,

        Omegadot__1,
        Omegadot__2,
        Omegadot__3
    ]):

StateDot :=
    simplify(
        Vector[column](24, [
            v__L1,
            v__L2,
            v__L3,

            qdot_alg[1],
            qdot_alg[2],
            qdot_alg[3],

            Rdot_vec_alg[1],
