<Group hide-input="false" labelreference="L74" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">M_alg :=
    Matrix(9, 9,
        (i,j) -&gt;
            simplify(
                diff(
                    diff(K_alg, GenVel_alg[i]),
                    GenVel_alg[j]
                )
            )
    ):

K_check :=
    simplify(
        K_alg
        - (1/2)*add(
            GenVel_alg[i]*(M_alg . GenVel_alg)[i],
            i=1..9
        )
    );</Text-field>
</Input>
