<Group hide-input="false" labelreference="L14" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Simulation:
read &quot;matlabsims.mpl&quot;:

# ----------------------------------------------------------
# physical/model parameters for the reduced outer-loop model
# ----------------------------------------------------------

parnames := [m__Q, m__L, L, g]:

# ----------------------------------------------------------
# flatten grouped gain/reference symbols from qsfa_terminal
# ----------------------------------------------------------

gain_syms_qsfa := [
    seq(op(fin[&quot;gain_symbols_all&quot;][i]), i = 1 .. nops(fin[&quot;gain_symbols_all&quot;]))
]:

ref_syms_qsfa := [
    seq(op(fin[&quot;reference_symbols_all&quot;][i]), i = 1 .. nops(fin[&quot;reference_symbols_all&quot;]))
]:

ctrl_parnames := [op(parnames), op(gain_syms_qsfa)]:

# ----------------------------------------------------------
# final QSFA controller expressions in original input order
# this exports U_d only
# ----------------------------------------------------------

u_qsfa_export := [
    seq(rhs(fin[&quot;feedback_Law&quot;][i]), i = 1 .. nops(fin[&quot;feedback_Law&quot;]))
]:

# ----------------------------------------------------------
# reference interface size for MATLAB generator
# ----------------------------------------------------------

nref_channels := nops(h):

maxord_qsfa := max(
    seq(
        sscanf(convert(ref_syms_qsfa[i], string), &quot;yr__%d__%d&quot;)[2],
        i = 1 .. nops(ref_syms_qsfa)
    )
):

# ----------------------------------------------------------
# export MATLAB files
# ----------------------------------------------------------

outdir := cat(currentdir(), kernelopts(dirsep), &quot;matlab_core_offset&quot;):
EnsureFolder(outdir):

WriteModelFile(
    outdir,
