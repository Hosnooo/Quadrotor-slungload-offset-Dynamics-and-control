<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">restart:

with(LinearAlgebra):
with(PDEtools):
with(DifferentialGeometry):
with(Tools):
with(Typesetting):

interface(rtablesize = 40):
Settings(typesetdot = true):

read &quot;MIMOTools.mpl&quot;:

printf(&quot;==================================================\134n&quot;):
printf(&quot;Offset outer-loop virtual-acceleration U model: construct xdot, f, G, equilibria\134n&quot;):
printf(&quot;==================================================\134n&quot;):

# ----------------------------------------------------------
# basic 3D vector operators
# ----------------------------------------------------------

Skew := proc(a)
    Matrix(3, 3, [
        [0,     -a[3],  a[2]],
        [a[3],   0,    -a[1]],
        [-a[2],  a[1],  0]
    ])
end proc:

Dot := proc(a,b)
    simplify(a[1]*b[1] + a[2]*b[2] + a[3]*b[3])
end proc:

# ----------------------------------------------------------
# states, inputs, outputs
# ----------------------------------------------------------

x := [
    x__P1, x__P2, x__P3,
    q__1, q__2, q__3,
    v__P1, v__P2, v__P3,
    omega__1, omega__2, omega__3
]:

u := [U__1, U__2, U__3]:

h := [x__P1, x__P2, x__P3]:

# ----------------------------------------------------------
# parameters and vector declarations
# ----------------------------------------------------------

e3 := Vector[column]([0, 0, 1]):

qvec := Vector[column]([
    q__1,
    q__2,
    q__3
]):

vvec := Vector[column]([
    v__P1,
    v__P2,
    v__P3
]):

omegavec := Vector[column]([
    omega__1,
    omega__2,
    omega__3
]):

Uvec := Vector[column]([
    U__1,
    U__2,
    U__3
]):

# ----------------------------------------------------------
# nonlinear outer-loop dynamics
#
# U is the suspension-point virtual acceleration input:
#   U = pddot - g*e3
#
# Reduced model:
#   xLdot    = vL
#   qdot     = omega x q
#   vLdot    = g e3 - L ||omega||^2 q + (U^T q) q
#   omegadot = -(1/L) q x U
# ----------------------------------------------------------

omega_sq := Dot(omegavec, omegavec):

pLdot := vvec:

qdot := simplify(
    Skew(omegavec) . qvec
):

vLdot := simplify(
    g*e3
    - L*omega_sq*qvec
    + Dot(Uvec, qvec)*qvec
):

omegadot := simplify(
    -(1/L)*(Skew(qvec) . Uvec)
):

xdot := Vector[column]([
    pLdot[1],
    pLdot[2],
    pLdot[3],

    qdot[1],
    qdot[2],
    qdot[3],

    vLdot[1],
    vLdot[2],
    vLdot[3],

    omegadot[1],
    omegadot[2],
    omegadot[3]
]):

# ----------------------------------------------------------
# construct affine form xdot = f + G u
# ----------------------------------------------------------

zero_input := [
    U__1 = 0,
    U__2 = 0,
    U__3 = 0
]:

f := simplify(
    subs(zero_input, xdot)
):

gmat := Matrix(
    RowDimension(xdot),
    nops(u),
    (i,j) -&gt; simplify(diff(xdot[i], u[j]))
):

affine_check := simplify(
    xdot - (f + gmat . Vector[column](u))
):

print(&quot;x =&quot;, x):
print(&quot;u =&quot;, u):
print(&quot;h =&quot;, h):

print(&quot;e3 =&quot;, e3):
print(&quot;qvec =&quot;, qvec):
print(&quot;vvec =&quot;, vvec):
print(&quot;omegavec =&quot;, omegavec):
print(&quot;Uvec =&quot;, Uvec):

print(&quot;omega_sq =&quot;, omega_sq):
print(&quot;pLdot =&quot;, pLdot):
print(&quot;qdot =&quot;, qdot):
print(&quot;vLdot =&quot;, vLdot):
print(&quot;omegadot =&quot;, omegadot):

print(&quot;xdot =&quot;, xdot):
print(&quot;f =&quot;, f):
print(&quot;gmat =&quot;, gmat):
print(&quot;affine_check =&quot;, affine_check):</Font></Text-field>
