<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ----------------------------------------------------------
# full equilibrium equations
# ----------------------------------------------------------

eqs_dyn := [
    seq(simplify(xdot[i]) = 0, i = 1 .. RowDimension(xdot))
]:

eqs_constraint := [
    Dot(qvec, qvec) = 1,
    Dot(omegavec, qvec) = 0
]:

eqs_equilibrium := [op(eqs_dyn), op(eqs_constraint)]:

# ----------------------------------------------------------
# solve all equilibria
# ----------------------------------------------------------

eq_unknowns_all := [
    q__1, q__2, q__3,
    v__P1, v__P2, v__P3,
    omega__1, omega__2, omega__3,
    U__1, U__2, U__3
]:

sol_eq_all := solve(eqs_equilibrium, eq_unknowns_all):

# ----------------------------------------------------------
# choose equilibrium branch
# branch 1 should be q = e3
# branch 2 should be q = -e3
# ----------------------------------------------------------

branch_index := 1:

sol_eq_selected := sol_eq_all[branch_index]:


x0 := [
    q__1 = simplify(subs(sol_eq_selected, q__1)),
    q__2 = simplify(subs(sol_eq_selected, q__2)),
    q__3 = simplify(subs(sol_eq_selected, q__3)),

    v__P1 = simplify(subs(sol_eq_selected, v__P1)),
    v__P2 = simplify(subs(sol_eq_selected, v__P2)),
    v__P3 = simplify(subs(sol_eq_selected, v__P3)),

    omega__1 = simplify(subs(sol_eq_selected, omega__1)),
    omega__2 = simplify(subs(sol_eq_selected, omega__2)),
    omega__3 = simplify(subs(sol_eq_selected, omega__3))
]:

u0 := [
    U__1 = simplify(subs(sol_eq_selected, U__1)),
    U__2 = simplify(subs(sol_eq_selected, U__2)),
    U__3 = simplify(subs(sol_eq_selected, U__3))
]:


print(&quot;sol_eq_all =&quot;, sol_eq_all):
print(&quot;sol_eq_selected =&quot;, sol_eq_selected):

print(&quot;x0 =&quot;, x0):
print(&quot;u0 =&quot;, u0):</Text-field>
</Input>
